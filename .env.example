# Bearer token clients must send as `Authorization: Bearer <token>`.
# Leave empty only for localhost-only experimentation — the shim logs a
# warning and accepts any POST when this is unset.
AGENT_SHIM_TOKEN=

# Address to listen on. Default: 127.0.0.1:18790
# Use 0.0.0.0:<port> only behind a trusted network boundary (Tailscale, VPN,
# reverse proxy). Never expose this port directly to the internet.
# AGENT_SHIM_BIND=127.0.0.1:18790

# Path to the openclaw CLI. Default: `openclaw` resolved via $PATH.
# Set explicitly if openclaw is installed under a custom location (e.g. nvm,
# asdf, /opt/...) that isn't on the systemd unit's PATH.
# AGENT_SHIM_OPENCLAW_BIN=openclaw

# Where per-run JSON state files are written. Default: /var/tmp/agent-shim/runs
# Created on startup if missing. Files are NOT cleaned up automatically.
# AGENT_SHIM_RUNS_DIR=/var/tmp/agent-shim/runs

# openclaw config consulted to validate that an incoming agent_id is actually
# registered. Default: $HOME/.openclaw/openclaw.json
# AGENT_SHIM_OPENCLAW_CONFIG=
